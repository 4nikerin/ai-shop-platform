{
  "name": "@ai-shop/contracts",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "prettier --check src"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./chat/*": {
      "types": "./dist/chat/*.d.ts",
      "default": "./dist/chat/*.js"
    },
    "./chatMessage/*": {
      "types": "./dist/chatMessage/*.d.ts",
      "default": "./dist/chatMessage/*.js"
    },
    "./order/*": {
      "types": "./dist/order/*.d.ts",
      "default": "./dist/order/*.js"
    },
    "./orderItem/*": {
      "types": "./dist/orderItem/*.d.ts",
      "default": "./dist/orderItem/*.js"
    },
    "./product/*": {
      "types": "./dist/product/*.d.ts",
      "default": "./dist/product/*.js"
    },
    "./productAttribute/*": {
      "types": "./dist/productAttribute/*.d.ts",
      "default": "./dist/productAttribute/*.js"
    },
    "./productAttributeOption/*": {
      "types": "./dist/productAttributeOption/*.d.ts",
      "default": "./dist/productAttributeOption/*.js"
    },
    "./productAttributeValue/*": {
      "types": "./dist/productAttributeValue/*.d.ts",
      "default": "./dist/productAttributeValue/*.js"
    },
    "./productImage/*": {
      "types": "./dist/productImage/*.d.ts",
      "default": "./dist/productImage/*.js"
    },
    "./user/*": {
      "types": "./dist/user/*.d.ts",
      "default": "./dist/user/*.js"
    }
  },
  "dependencies": {
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "prettier": "^3.8.3",
    "typescript": "~6.0.2"
  }
}
